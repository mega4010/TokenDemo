# WalletConnect v2 (required for WalletConnect option in Connect Wallet dialog)
# Get your project ID at https://cloud.walletconnect.com
REACT_APP_WALLETCONNECT_PROJECT_ID=

# Moralis (for swap, NFTs, etc.). Create a server at https://moralis.io and set:
# REACT_APP_MORALIS_APPLICATION_ID=your_app_id
# REACT_APP_MORALIS_SERVER_URL=https://xxxxx.your-server.com:2053/server
# If unset, the app uses a legacy demo URL that may no longer resolve (ERR_NAME_NOT_RESOLVED).
REACT_APP_MORALIS_APPLICATION_ID=
REACT_APP_MORALIS_SERVER_URL=
